generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model ContactSubmission {
  id        String   @id @default(cuid())
  fullName  String
  phone     String
  email     String
  company   String
  referral  String
  message   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
